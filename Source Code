<script>
// ========= DATA =========
const categories = [
  {
    id:'spinning', name:'Spinning', icon:'🧵', desc:'Ring and open-end spinning frames',
    machines:[
      {id:'M-01',name:'Ring Frame RF-01',health:88,status:'good',vibration:2.1,temp:52,current:10.2,fatigue:34,lastService:'12 Mar 2025',nextService:'12 Jun 2025',uptime:97.2,alerts:[]},
      {id:'M-02',name:'Ring Frame RF-02',health:82,status:'good',vibration:2.8,temp:58,current:10.9,fatigue:41,lastService:'1 Mar 2025',nextService:'1 Jun 2025',uptime:96.1,alerts:['Belt inspection due Friday']},
      {id:'M-03',name:'Open-End OE-01',health:61,status:'warn',vibration:4.1,temp:66,current:12.4,fatigue:68,lastService:'10 Jan 2025',nextService:'Overdue',uptime:88.4,alerts:['Vibration above normal','Service overdue']},
      {id:'M-04',name:'Open-End OE-02',health:6,status:'critical',vibration:8.7,temp:87,current:12.1,fatigue:94,lastService:'5 Dec 2024',nextService:'Overdue',uptime:61.0,alerts:['CRITICAL: Bearing failure imminent','Temperature critical','Fatigue score 94/100']},
    ]
  },
  {
    id:'weaving', name:'Weaving', icon:'🪢', desc:'Rapier and projectile looms',
    machines:[
      {id:'M-05',name:'Rapier Loom RL-01',health:91,status:'good',vibration:1.8,temp:48,current:9.4,fatigue:22,lastService:'20 Mar 2025',nextService:'20 Jun 2025',uptime:98.1,alerts:[]},
      {id:'M-06',name:'Rapier Loom RL-02',health:79,status:'good',vibration:3.2,temp:61,current:11.1,fatigue:55,lastService:'14 Feb 2025',nextService:'14 May 2025',uptime:93.7,alerts:['Tension sensor drift — minor']},
      {id:'M-09',name:'Projectile Loom PL-01',health:52,status:'warn',vibration:3.9,temp:74,current:13.1,fatigue:71,lastService:'22 Nov 2024',nextService:'Overdue',uptime:81.2,alerts:['Overheating detected','Cooling fan RPM drop']},
    ]
  },
  {
    id:'winding', name:'Winding & Reeling', icon:'🎣', desc:'Cone winding and reeling machines',
    machines:[
      {id:'M-07',name:'Cone Winder CW-01',health:85,status:'good',vibration:2.3,temp:54,current:8.7,fatigue:38,lastService:'5 Mar 2025',nextService:'5 Jun 2025',uptime:95.8,alerts:['Belt inspection due Friday']},
      {id:'M-08',name:'Cone Winder CW-02',health:90,status:'good',vibration:1.9,temp:49,current:8.2,fatigue:29,lastService:'18 Mar 2025',nextService:'18 Jun 2025',uptime:97.5,alerts:[]},
    ]
  },
  {
    id:'processing', name:'Processing & Finishing', icon:'⚙️', desc:'Dyeing, bleaching and finishing units',
    machines:[
      {id:'M-10',name:'Dyeing Unit DU-01',health:76,status:'good',vibration:2.7,temp:63,current:11.8,fatigue:48,lastService:'28 Feb 2025',nextService:'28 May 2025',uptime:92.3,alerts:[]},
      {id:'M-11',name:'Finishing Unit FU-01',health:61,status:'warn',vibration:3.6,temp:68,current:14.2,fatigue:65,lastService:'15 Jan 2025',nextService:'Overdue',uptime:85.9,alerts:['Current draw anomaly','Lubrication required']},
      {id:'M-12',name:'Bleaching Unit BU-01',health:94,status:'good',vibration:1.4,temp:44,current:7.9,fatigue:18,lastService:'22 Mar 2025',nextService:'22 Jun 2025',uptime:99.1,alerts:[]},
    ]
  }
];

const allMachines = categories.flatMap(c => c.machines.map(m => ({...m, categoryId:c.id, categoryName:c.name})));

const limits = {vibration:5.0, temp:70, current:13.0, fatigue:80};

const recs = {
  critical:[
    {action:'Replace bearing — failure predicted within 48 hours',cost:'₹1,200',time:'2 hrs',pri:'high'},
    {action:'Full inspection and diagnostic shutdown recommended',cost:'₹500',time:'4 hrs',pri:'high'},
  ],
  warn:[
    {action:'Clean cooling duct and inspect fan motor',cost:'₹300',time:'45 min',pri:'high'},
    {action:'Lubricate shuttle mechanism',cost:'₹200',time:'30 min',pri:'med'},
    {action:'Recalibrate tension sensor',cost:'₹150',time:'20 min',pri:'med'},
  ],
  good:[
    {action:'Routine belt inspection (scheduled)',cost:'₹0',time:'30 min',pri:'low'},
    {action:'Log current readings for baseline update',cost:'₹0',time:'10 min',pri:'low'},
  ]
};

// ========= HELPERS =========
function statusColor(s){return s==='good'?'var(--green)':s==='warn'?'var(--amber)':'var(--red)'}
function statusLabel(s){return s==='good'?'Healthy':s==='warn'?'Warning':'Critical'}
function healthColor(h){return h>70?'var(--green)':h>40?'var(--amber)':'var(--red)'}
function fatigueColor(f){return f<40?'var(--green)':f<70?'var(--amber)':'var(--red)'}

function catBorderClass(cat){
  if(cat.machines.some(m=>m.status==='critical')) return 'border-crit glow-red';
  if(cat.machines.some(m=>m.status==='warn')) return 'border-warn';
  return 'border-good';
}

function avgHealth(cat){
  return Math.round(cat.machines.reduce((a,m)=>a+m.health,0)/cat.machines.length);
}

// ========= CLOCK =========
setInterval(()=>{
  const now=new Date();
  document.getElementById('clock').textContent=now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
},1000);

// ========= PAGES =========
let currentMachineId = null;
let currentCategoryId = null;
let machTrendChart=null, machUptimeChart=null;
let ovCharts=[];

function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  if(id==='home') document.getElementById('tab-home').classList.add('active');
  if(id==='overview') document.getElementById('tab-overview').classList.add('active');
}

function setBreadcrumb(crumbs){
  const bc=document.getElementById('breadcrumb');
  bc.innerHTML=crumbs.map((c,i)=>{
    const isLast=i===crumbs.length-1;
    return (i>0?`<span class="nav-sep">›</span>`:'') +
      `<span class="nav-crumb${isLast?' active':''}" ${c.onclick?`onclick="${c.onclick}"`:''} style="${isLast?'':'cursor:pointer'}">${c.label}</span>`;
  }).join('');
}

function goHome(){
  showPage('home');
  setBreadcrumb([{label:'Plant Floor'}]);
  renderHome();
}

function goOverview(){
  showPage('overview');
  setBreadcrumb([{label:'Plant Floor',onclick:'goHome()'},null,{label:'Overview'}].filter(Boolean));
  renderOverview();
}

function goCategory(catId){
  currentCategoryId=catId;
  showPage('category');
  const cat=categories.find(c=>c.id===catId);
  setBreadcrumb([{label:'Plant Floor',onclick:'goHome()'},{label:cat.name}]);
  renderCategory(cat);
}

function goMachine(machId, fromCatId){
  currentMachineId=machId;
  const m=allMachines.find(x=>x.id===machId);
  showPage('machine');
  const cat=categories.find(c=>c.id===m.categoryId);
  setBreadcrumb([
    {label:'Plant Floor',onclick:'goHome()'},
    {label:cat.name,onclick:`goCategory('${cat.id}')`},
    {label:m.name}
  ]);
  document.getElementById('mach-back-btn').onclick=()=>goCategory(m.categoryId);
  renderMachine(m);
}

// ========= HOME RENDER =========
function renderHome(){
  const total=allMachines.length;
  const crit=allMachines.filter(m=>m.status==='critical').length;
  const warn=allMachines.filter(m=>m.status==='warn').length;
  const good=allMachines.filter(m=>m.status==='good').length;

  document.getElementById('summary-pills').innerHTML=`
    <div class="pill pill-total"><span class="pill-dot" style="background:var(--text2)"></span>${total} Total</div>
    <div class="pill pill-crit"><span class="pill-dot"></span>${crit} Critical</div>
    <div class="pill pill-warn"><span class="pill-dot"></span>${warn} Warning</div>
    <div class="pill pill-good"><span class="pill-dot"></span>${good} Healthy</div>
  `;

  const grid=document.getElementById('cat-grid');
  grid.innerHTML=categories.map(cat=>{
    const avg=avgHealth(cat);
    const critCount=cat.machines.filter(m=>m.status==='critical').length;
    const warnCount=cat.machines.filter(m=>m.status==='warn').length;
    const goodCount=cat.machines.filter(m=>m.status==='good').length;
    const fillColor=critCount>0?'var(--red)':warnCount>0?'var(--amber)':'var(--green)';
    return `<div class="cat-card ${catBorderClass(cat)}" onclick="goCategory('${cat.id}')">
      <span class="cat-icon">${cat.icon}</span>
      <div class="cat-name">${cat.name}</div>
      <div class="cat-desc">${cat.desc}</div>
      <div class="cat-footer">
        <span class="cat-count">${cat.machines.length} machines</span>
        <div class="cat-status-row">
          ${goodCount>0?`<div class="cat-status-item" style="color:var(--green)"><span style="width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block"></span>${goodCount} ok</div>`:''}
          ${warnCount>0?`<div class="cat-status-item" style="color:var(--amber)"><span style="width:6px;height:6px;border-radius:50%;background:var(--amber);display:inline-block"></span>${warnCount} warn</div>`:''}
          ${critCount>0?`<div class="cat-status-item" style="color:var(--red)"><span style="width:6px;height:6px;border-radius:50%;background:var(--red);display:inline-block"></span>${critCount} crit</div>`:''}
        </div>
      </div>
      <div class="cat-health-bar"><div class="cat-health-fill" style="width:${avg}%;background:${fillColor}"></div></div>
      <div style="font-size:10px;color:var(--text3);margin-top:4px;text-align:right">Avg health: ${avg}%</div>
    </div>`;
  }).join('');

  const alertsStrip=document.getElementById('alerts-strip');
  const recentAlerts=allMachines.filter(m=>m.alerts.length>0).flatMap(m=>m.alerts.map(a=>({text:a,machine:m.id,sev:m.status})));
  alertsStrip.innerHTML=recentAlerts.slice(0,6).map(a=>`
    <div class="alert-chip ${a.sev==='critical'?'crit':'warn'}">
      <span>${a.sev==='critical'?'⚠':'●'}</span>
      <span>${a.machine}: ${a.text}</span>
    </div>`).join('');
}

// ========= OVERVIEW RENDER =========
function renderOverview(){
  ovCharts.forEach(c=>{try{c.destroy()}catch(e){}});
  ovCharts=[];

  const c1=new Chart(document.getElementById('ov-trend'),{
    type:'line',
    data:{labels:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],datasets:[{label:'Fleet health %',data:[84,83,80,78,77,75,71],borderColor:'rgb(120,100,255)',backgroundColor:'rgba(120,100,255,0.08)',tension:0.4,fill:true,pointRadius:4,pointBackgroundColor:'rgb(120,100,255)',borderWidth:2}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{min:60,max:100,grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b90a0',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#8b90a0',font:{size:10}}}}}
  });
  ovCharts.push(c1);

  const c2=new Chart(document.getElementById('ov-fault'),{
    type:'doughnut',
    data:{labels:['Vibration','Overheating','Current anomaly','Belt wear'],datasets:[{data:[38,27,21,14],backgroundColor:['rgb(255,75,80)','rgb(255,180,50)','rgb(60,160,255)','rgb(50,210,130)'],borderWidth:0,hoverOffset:6}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'65%',plugins:{legend:{position:'right',labels:{color:'#8b90a0',font:{size:11},boxWidth:10,padding:8}}}}
  });
  ovCharts.push(c2);

  const c3=new Chart(document.getElementById('ov-sensor'),{
    type:'bar',
    data:{
      labels:['Vibration (mm/s)','Temperature (°C)','Current (A)','Fatigue Score'],
      datasets:[
        {label:'Current reading',data:[8.7,87,12.1,94],backgroundColor:['rgba(255,75,80,0.8)','rgba(255,75,80,0.8)','rgba(255,180,50,0.8)','rgba(255,75,80,0.8)'],borderRadius:4},
        {label:'Safe limit',data:[5.0,70,13.0,80],backgroundColor:'rgba(255,255,255,0.08)',borderRadius:4}
      ]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#8b90a0',font:{size:10},boxWidth:10}}},scales:{y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b90a0',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#8b90a0',font:{size:10}}}}}
  });
  ovCharts.push(c3);

  const c4=new Chart(document.getElementById('ov-roi'),{
    type:'bar',
    data:{
      labels:['Oct','Nov','Dec','Jan','Feb','Mar'],
      datasets:[
        {label:'Savings (₹K)',data:[6,9,12,14,13,15],backgroundColor:'rgba(50,210,130,0.75)',borderRadius:4},
        {label:'Cost (₹K)',data:[5.7,5.7,5.7,5.7,5.7,5.7],backgroundColor:'rgba(255,255,255,0.08)',borderRadius:4}
      ]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#8b90a0',font:{size:10},boxWidth:10}}},scales:{y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b90a0',font:{size:10},callback:v=>'₹'+v+'K'}},x:{grid:{display:false},ticks:{color:'#8b90a0',font:{size:10}}}}}
  });
  ovCharts.push(c4);

  const list=document.getElementById('ov-machine-list');
  list.innerHTML=allMachines.map(m=>`
    <div class="machine-list-row" onclick="goMachine('${m.id}')">
      <div class="m-dot" style="background:${statusColor(m.status)}"></div>
      <div class="m-info"><div class="m-name">${m.name}</div><div class="m-type">${m.categoryName}</div></div>
      <div class="m-bar-wrap"><div class="m-bar" style="width:${m.health}%;background:${healthColor(m.health)}"></div></div>
      <div class="m-pct" style="color:${healthColor(m.health)}">${m.health}%</div>
    </div>`).join('');
}

// ========= CATEGORY RENDER =========
function renderCategory(cat){
  const avg=avgHealth(cat);
  const critC=cat.machines.filter(m=>m.status==='critical').length;
  const alertC=cat.machines.reduce((a,m)=>a+m.alerts.length,0);

  document.getElementById('cat-header').innerHTML=`
    <div class="cat-page-icon">${cat.icon}</div>
    <div>
      <div class="cat-page-title">${cat.name}</div>
      <div class="cat-page-desc">${cat.desc}</div>
      <div class="cat-meta-pills">
        <span class="meta-pill">${cat.machines.length} machines</span>
        <span class="meta-pill" style="color:${avg>70?'var(--green)':avg>40?'var(--amber)':'var(--red)'}">Avg health: ${avg}%</span>
        ${alertC>0?`<span class="meta-pill" style="color:var(--red)">${alertC} active alerts</span>`:'<span class="meta-pill" style="color:var(--green)">No critical alerts</span>'}
      </div>
    </div>
  `;

  document.getElementById('cat-machine-grid').innerHTML=cat.machines.map(m=>`
    <div class="mach-card ${m.status}" onclick="goMachine('${m.id}')">
      <div class="mach-card-top">
        <span class="mach-id">${m.id}</span>
        <span class="status-badge ${m.status}">${statusLabel(m.status)}</span>
      </div>
      <div class="mach-name">${m.name}</div>
      <div class="mach-health-big" style="color:${healthColor(m.health)}">${m.health}%</div>
      <div class="mach-bar-wrap"><div class="mach-bar" style="width:${m.health}%;background:${healthColor(m.health)}"></div></div>
      <div class="sensor-pills">
        <span class="sensor-pill">📳 ${m.vibration} mm/s</span>
        <span class="sensor-pill">🌡 ${m.temp}°C</span>
        <span class="sensor-pill">⚡ ${m.current}A</span>
      </div>
      <div class="fatigue-row">
        <div class="fatigue-label"><span>Fatigue</span><span style="color:${fatigueColor(m.fatigue)}">${m.fatigue}/100</span></div>
        <div class="fatigue-bar-wrap"><div class="fatigue-bar" style="width:${m.fatigue}%;background:${fatigueColor(m.fatigue)}"></div></div>
      </div>
      <div class="mach-card-footer">
        ${m.alerts.length>0?`<span class="alert-badge">⚠ ${m.alerts.length} alert${m.alerts.length>1?'s':''}</span>`:'<span style="font-size:11px;color:var(--green)">✓ No alerts</span>'}
        <span class="view-btn">View analytics →</span>
      </div>
    </div>`).join('');
}

// ========= MACHINE RENDER =========
function renderMachine(m){
  if(machTrendChart){try{machTrendChart.destroy()}catch(e){}}
  if(machUptimeChart){try{machUptimeChart.destroy()}catch(e){}}

  document.getElementById('mach-header').innerHTML=`
    <div class="mach-detail-title-row">
      <div class="mach-detail-title">${m.name}</div>
      <span class="mach-id">${m.id}</span>
      <span class="status-badge ${m.status}">${statusLabel(m.status)}</span>
    </div>
    <div class="info-pills-row">
      <div class="info-pill">Last service: <strong>${m.lastService}</strong></div>
      <div class="info-pill">Next service: <strong style="color:${m.nextService==='Overdue'?'var(--red)':'var(--text)'}">${m.nextService}</strong></div>
      <div class="info-pill">Uptime today: <strong style="color:${m.uptime>90?'var(--green)':m.uptime>80?'var(--amber)':'var(--red)'}">${m.uptime}%</strong></div>
    </div>
  `;

  const sensors=[
    {label:'Vibration',val:m.vibration,unit:'mm/s',limit:limits.vibration},
    {label:'Temperature',val:m.temp,unit:'°C',limit:limits.temp},
    {label:'Current draw',val:m.current,unit:'A',limit:limits.current},
    {label:'Fatigue score',val:m.fatigue,unit:'/100',limit:limits.fatigue},
  ];
  document.getElementById('mach-sensors').innerHTML=sensors.map(s=>{
    const pct=Math.min(100,Math.round((s.val/s.limit)*100));
    const sc=pct>100?'crit':pct>80?'warn':'good';
    const col=sc==='good'?'var(--green)':sc==='warn'?'var(--amber)':'var(--red)';
    return `<div class="sensor-card ${sc}">
      <div class="sensor-card-label">${s.label}</div>
      <div class="sensor-card-val" style="color:${col}">${s.val}</div>
      <div class="sensor-card-unit">${s.unit}</div>
      <div class="sensor-card-limit">Limit: ${s.limit}${s.unit}</div>
      <div class="sensor-prog-wrap"><div class="sensor-prog" style="width:${Math.min(100,pct)}%;background:${col}"></div></div>
    </div>`;
  }).join('');

  // Generate 24hr trend
  const hours=Array.from({length:24},(_,i)=>`${i}:00`);
  const trendVib=hours.map((_,i)=>{
    if(m.status==='critical') return +(m.vibration * (0.55 + 0.45*(i/23)) + (Math.random()-0.5)*0.3).toFixed(1);
    return +(m.vibration + (Math.random()-0.5)*0.6).toFixed(1);
  });
  const trendTemp=hours.map((_,i)=>{
    if(m.status==='critical') return Math.round(m.temp * (0.75 + 0.25*(i/23)) + (Math.random()-0.5)*2);
    return Math.round(m.temp + (Math.random()-0.5)*4);
  });

  machTrendChart=new Chart(document.getElementById('mach-trend'),{
    type:'line',
    data:{
      labels:hours.filter((_,i)=>i%4===0),
      datasets:[
        {label:'Vibration (mm/s)',data:trendVib.filter((_,i)=>i%4===0),borderColor:'rgb(255,75,80)',backgroundColor:'rgba(255,75,80,0.05)',tension:0.4,yAxisID:'y',pointRadius:2,borderWidth:2},
        {label:'Temp (°C)',data:trendTemp.filter((_,i)=>i%4===0),borderColor:'rgb(255,180,50)',backgroundColor:'rgba(255,180,50,0.05)',tension:0.4,yAxisID:'y1',pointRadius:2,borderWidth:2}
      ]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#8b90a0',font:{size:10},boxWidth:10}}},scales:{
      y:{position:'left',grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b90a0',font:{size:10}}},
      y1:{position:'right',grid:{display:false},ticks:{color:'#8b90a0',font:{size:10}}},
      x:{grid:{display:false},ticks:{color:'#8b90a0',font:{size:10}}}
    }}
  });

  // Uptime 7 days
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const uptimeData=days.map((_,i)=>{
    if(m.status==='critical') return Math.max(55, Math.round(m.uptime * (1 + 0.06*(1-i/6)) + (Math.random()-0.5)*3));
    if(m.status==='warn') return Math.round(m.uptime + (Math.random()-0.5)*5);
    return Math.min(100, Math.round(m.uptime + (Math.random()-0.5)*2));
  });

  machUptimeChart=new Chart(document.getElementById('mach-uptime'),{
    type:'bar',
    data:{labels:days,datasets:[{label:'Uptime %',data:uptimeData,backgroundColor:uptimeData.map(v=>v>90?'rgba(50,210,130,0.7)':v>80?'rgba(255,180,50,0.7)':'rgba(255,75,80,0.7)'),borderRadius:4}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{min:50,max:100,grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b90a0',font:{size:10},callback:v=>v+'%'}},x:{grid:{display:false},ticks:{color:'#8b90a0',font:{size:10}}}}}
  });

  // Alerts
  const alertsEl=document.getElementById('mach-alerts');
  if(m.alerts.length===0){
    alertsEl.innerHTML=`<div class="no-alerts"><span>✓</span> All systems normal — no active alerts</div>`;
  } else {
    alertsEl.innerHTML=m.alerts.map(a=>{
      const isCrit=a.toLowerCase().includes('critical')||a.toLowerCase().includes('failure');
      return `<div class="alert-list-item ${isCrit?'crit':'warn'}">
        <span class="alert-icon">${isCrit?'⚠':'●'}</span>
        <div><div class="alert-text">${a}</div><div class="alert-sub">${m.id} · ${new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</div></div>
      </div>`;
    }).join('');
  }

  // Recommendations
  const recList=m.status==='critical'?recs.critical:m.status==='warn'?recs.warn:recs.good;
  document.getElementById('mach-recs').innerHTML=recList.map(r=>`
    <tr>
      <td>${r.action}</td>
      <td>${r.cost}</td>
      <td>${r.time}</td>
      <td><span class="pri-badge pri-${r.pri}">${r.pri}</span></td>
    </tr>`).join('');

  // Fatigue
  document.getElementById('fatigue-score-label').textContent=`${m.fatigue}/100`;
  document.getElementById('fatigue-score-label').style.color=fatigueColor(m.fatigue);
  document.getElementById('fatigue-pointer').style.left=`${m.fatigue}%`;
  document.getElementById('fatigue-pointer').setAttribute('data-val',`${m.fatigue}`);
  const pred=m.fatigue>90?'⚠ Estimated time to failure: < 48 hours — immediate action required':
    m.fatigue>70?'⏱ Estimated time to service: 1–2 weeks — schedule maintenance soon':
    '✓ On schedule — next service as planned';
  const predCol=m.fatigue>90?'var(--red)':m.fatigue>70?'var(--amber)':'var(--green)';
  document.getElementById('fatigue-prediction').innerHTML=`<strong style="color:${predCol}">${pred}</strong>`;

  // Real-time simulation
  clearInterval(window._liveInterval);
  window._liveInterval=setInterval(()=>{
    const cards=document.querySelectorAll('.sensor-card-val');
    if(cards.length<2) return;
    const newVib=Math.max(0.5,(m.vibration+(Math.random()-0.5)*0.4)).toFixed(1);
    const newTemp=Math.round(m.temp+(Math.random()-0.5)*2);
    cards[0].textContent=newVib;
    cards[1].textContent=newTemp;
  },5000);
}

// ========= INIT =========
Chart.defaults.color='#8b90a0';
goHome();
</script>
</body>
</html>
