<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LoomGuard — Predict. Prevent. Perform.</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0b0f;
  --bg2: #111318;
  --bg3: #191c24;
  --bg4: #1f2330;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #e8eaf0;
  --text2: #8b90a0;
  --text3: #555a6a;
  --purple: rgb(120,100,255);
  --purple2: rgb(90,70,220);
  --purple-dim: rgba(120,100,255,0.12);
  --green: rgb(50,210,130);
  --green-dim: rgba(50,210,130,0.12);
  --amber: rgb(255,180,50);
  --amber-dim: rgba(255,180,50,0.12);
  --red: rgb(255,75,80);
  --red-dim: rgba(255,75,80,0.12);
  --blue: rgb(60,160,255);
  --blue-dim: rgba(60,160,255,0.12);
  --teal: rgb(30,210,200);
  --teal-dim: rgba(30,210,200,0.1);
  --radius: 12px;
  --radius-sm: 8px;
  --radius-xs: 5px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
h1,h2,h3,.mono{font-family:'Space Grotesk',sans-serif}

/* Scrollbar */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg2)}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:4px}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(10,11,15,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 2rem;height:58px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;cursor:pointer}
.nav-logo-mark{width:30px;height:30px;background:linear-gradient(135deg,rgb(120,100,255),rgb(60,160,255));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;font-family:'Space Grotesk',sans-serif;color:#fff}
.nav-logo-text{font-size:17px;font-weight:600;font-family:'Space Grotesk',sans-serif;color:var(--text)}
.nav-logo-text span{color:var(--purple)}
.nav-center{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2)}
.nav-sep{color:var(--text3);margin:0 2px}
.nav-crumb{cursor:pointer;padding:4px 8px;border-radius:var(--radius-xs);transition:all 0.15s}
.nav-crumb:hover{background:var(--bg3);color:var(--text)}
.nav-crumb.active{color:var(--purple)}
.nav-right{display:flex;align-items:center;gap:14px}
.live-badge{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--green);font-weight:500}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse-green 2s infinite}
@keyframes pulse-green{0%,100%{box-shadow:0 0 0 0 rgba(50,210,130,0.4)}50%{box-shadow:0 0 0 5px rgba(50,210,130,0)}}
.nav-time{font-size:12px;color:var(--text2);font-family:'Space Grotesk',sans-serif}
.nav-tabs{display:flex;gap:2px}
.nav-tab{font-size:13px;padding:5px 12px;border-radius:var(--radius-xs);cursor:pointer;color:var(--text2);transition:all 0.15s;border:none;background:transparent}
.nav-tab:hover{color:var(--text);background:var(--bg3)}
.nav-tab.active{color:var(--purple);background:var(--purple-dim)}

/* PAGES */
.page{display:none;animation:fadeIn 0.25s ease}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.container{max-width:1200px;margin:0 auto;padding:2rem}

/* HOME */
.home-hero{padding:2.5rem 0 1.5rem;border-bottom:1px solid var(--border);margin-bottom:2rem}
.home-hero-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.25rem}
.home-title{font-size:28px;font-weight:700;color:var(--text);line-height:1.2}
.home-title span{background:linear-gradient(90deg,rgb(120,100,255),rgb(60,160,255));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.home-sub{font-size:14px;color:var(--text2);margin-top:4px}
.pill-row{display:flex;gap:10px;flex-wrap:wrap}
.pill{display:flex;align-items:center;gap:7px;padding:6px 14px;border-radius:20px;font-size:13px;font-weight:500;border:1px solid}
.pill-total{background:var(--bg3);border-color:var(--border2);color:var(--text)}
.pill-crit{background:var(--red-dim);border-color:rgba(255,75,80,0.3);color:var(--red)}
.pill-warn{background:var(--amber-dim);border-color:rgba(255,180,50,0.3);color:var(--amber)}
.pill-good{background:var(--green-dim);border-color:rgba(50,210,130,0.3);color:var(--green)}
.pill-dot{width:6px;height:6px;border-radius:50%;background:currentColor}

/* CATEGORY CARDS */
.cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:2rem}
.cat-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden}
.cat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--radius) var(--radius) 0 0;transition:opacity 0.2s}
.cat-card.border-good::before{background:linear-gradient(90deg,var(--green),var(--teal))}
.cat-card.border-warn::before{background:linear-gradient(90deg,var(--amber),rgb(255,140,50))}
.cat-card.border-crit::before{background:linear-gradient(90deg,var(--red),rgb(220,50,120))}
.cat-card:hover{border-color:var(--border2);transform:translateY(-2px);background:var(--bg3)}
.cat-icon{font-size:36px;margin-bottom:0.75rem;display:block}
.cat-name{font-size:18px;font-weight:600;color:var(--text);margin-bottom:4px}
.cat-desc{font-size:13px;color:var(--text2);margin-bottom:1rem;line-height:1.5}
.cat-footer{display:flex;align-items:center;justify-content:space-between}
.cat-count{font-size:12px;color:var(--text3);background:var(--bg4);padding:3px 10px;border-radius:10px}
.cat-status-row{display:flex;gap:10px}
.cat-status-item{display:flex;align-items:center;gap:4px;font-size:11px;font-weight:500}
.cat-health-bar{height:4px;background:var(--bg4);border-radius:2px;margin-top:0.85rem;overflow:hidden}
.cat-health-fill{height:4px;border-radius:2px;transition:width 0.5s ease}

/* ALERTS STRIP */
.alerts-strip-title{font-size:13px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:0.75rem}
.alerts-strip{display:flex;gap:10px;overflow-x:auto;padding-bottom:8px}
.alerts-strip::-webkit-scrollbar{height:3px}
.alert-chip{flex-shrink:0;display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:20px;font-size:12px;font-weight:500;border:1px solid;white-space:nowrap}
.alert-chip.crit{background:var(--red-dim);border-color:rgba(255,75,80,0.3);color:var(--red)}
.alert-chip.warn{background:var(--amber-dim);border-color:rgba(255,180,50,0.3);color:var(--amber)}

/* METRIC CARDS */
.metric-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.5rem}
.metric-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.25rem}
.metric-label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:6px}
.metric-val{font-size:26px;font-weight:700;font-family:'Space Grotesk',sans-serif;line-height:1}
.metric-sub{font-size:11px;color:var(--text3);margin-top:4px}
.metric-val.good{color:var(--green)}
.metric-val.warn{color:var(--amber)}
.metric-val.crit{color:var(--red)}
.metric-val.purple{color:var(--purple)}

/* OVERVIEW CHARTS */
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.chart-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem}
.chart-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:1rem}
.chart-sub{font-size:11px;color:var(--text2);margin-bottom:1rem}
.chart-wrap{position:relative;width:100%}

/* MACHINE LIST IN OVERVIEW */
.machine-list-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;margin-bottom:16px}
.machine-list-row{display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:all 0.15s;border-radius:var(--radius-xs);padding-left:6px;padding-right:6px}
.machine-list-row:last-child{border-bottom:none}
.machine-list-row:hover{background:var(--bg3)}
.m-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.m-info{flex:1}
.m-name{font-size:13px;font-weight:500;color:var(--text)}
.m-type{font-size:11px;color:var(--text2)}
.m-bar-wrap{width:90px;height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.m-bar{height:5px;border-radius:3px}
.m-pct{font-size:12px;font-weight:600;min-width:34px;text-align:right;font-family:'Space Grotesk',sans-serif}

/* CATEGORY PAGE */
.cat-page-header{display:flex;align-items:center;gap:1rem;padding:1.5rem 0;border-bottom:1px solid var(--border);margin-bottom:1.5rem}
.cat-page-icon{font-size:48px}
.cat-page-title{font-size:24px;font-weight:700;color:var(--text)}
.cat-page-desc{font-size:14px;color:var(--text2);margin-top:3px}
.cat-meta-pills{display:flex;gap:8px;margin-top:0.75rem}
.meta-pill{font-size:12px;padding:4px 12px;border-radius:12px;background:var(--bg3);border:1px solid var(--border);color:var(--text2)}

/* MACHINE CARDS IN CATEGORY */
.mach-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.mach-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;cursor:pointer;transition:all 0.2s;border-left:3px solid transparent;position:relative}
.mach-card.good{border-left-color:var(--green)}
.mach-card.warn{border-left-color:var(--amber)}
.mach-card.critical{border-left-color:var(--red)}
.mach-card:hover{background:var(--bg3);transform:translateY(-2px)}
.mach-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:0.75rem}
.mach-id{font-size:11px;font-weight:600;background:var(--bg4);padding:3px 8px;border-radius:4px;color:var(--text2);font-family:'Space Grotesk',sans-serif}
.status-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:10px;text-transform:uppercase;letter-spacing:0.5px}
.status-badge.good{background:var(--green-dim);color:var(--green)}
.status-badge.warn{background:var(--amber-dim);color:var(--amber)}
.status-badge.critical{background:var(--red-dim);color:var(--red);animation:flicker 2s infinite}
@keyframes flicker{0%,100%{opacity:1}50%{opacity:0.7}}
.mach-name{font-size:15px;font-weight:600;color:var(--text);margin-bottom:0.5rem}
.mach-health-big{font-size:32px;font-weight:700;font-family:'Space Grotesk',sans-serif;line-height:1;margin-bottom:0.4rem}
.mach-bar-wrap{height:6px;background:var(--bg4);border-radius:3px;margin-bottom:0.85rem;overflow:hidden}
.mach-bar{height:6px;border-radius:3px}
.sensor-pills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:0.75rem}
.sensor-pill{font-size:11px;padding:3px 9px;border-radius:8px;background:var(--bg4);color:var(--text2);font-family:'Space Grotesk',sans-serif}
.fatigue-row{margin-bottom:0.85rem}
.fatigue-label{display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-bottom:4px}
.fatigue-bar-wrap{height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.fatigue-bar{height:5px;border-radius:3px}
.mach-card-footer{display:flex;align-items:center;justify-content:space-between}
.alert-badge{font-size:11px;background:var(--red-dim);color:var(--red);padding:3px 9px;border-radius:10px;font-weight:500}
.view-btn{font-size:12px;color:var(--purple);font-weight:500;display:flex;align-items:center;gap:4px}

/* MACHINE DETAIL */
.mach-detail-header{padding:1.5rem 0;border-bottom:1px solid var(--border);margin-bottom:1.5rem}
.mach-detail-title-row{display:flex;align-items:center;gap:12px;margin-bottom:0.75rem}
.mach-detail-title{font-size:24px;font-weight:700;color:var(--text)}
.info-pills-row{display:flex;gap:8px;flex-wrap:wrap}
.info-pill{font-size:12px;padding:5px 14px;border-radius:10px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);display:flex;align-items:center;gap:6px}
.info-pill strong{color:var(--text);font-weight:500}

/* SENSOR CARDS */
.sensor-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.5rem}
.sensor-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem;position:relative;overflow:hidden}
.sensor-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px}
.sensor-card.good::after{background:var(--green)}
.sensor-card.warn::after{background:var(--amber)}
.sensor-card.crit::after{background:var(--red)}
.sensor-card-label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:6px}
.sensor-card-val{font-size:28px;font-weight:700;font-family:'Space Grotesk',sans-serif;line-height:1;margin-bottom:2px}
.sensor-card-unit{font-size:11px;color:var(--text3);margin-bottom:8px}
.sensor-card-limit{font-size:11px;color:var(--text2);margin-bottom:8px}
.sensor-prog-wrap{height:4px;background:var(--bg4);border-radius:2px;overflow:hidden}
.sensor-prog{height:4px;border-radius:2px;transition:width 0.6s ease}

/* SECTIONS */
.section{margin-bottom:1.5rem}
.section-title{font-size:14px;font-weight:600;color:var(--text);margin-bottom:1rem;display:flex;align-items:center;gap:8px}
.section-title::after{content:'';flex:1;height:1px;background:var(--border)}

/* ALERTS LIST */
.alert-list-item{display:flex;align-items:flex-start;gap:12px;padding:12px;border-radius:var(--radius-sm);margin-bottom:8px;border:1px solid}
.alert-list-item.crit{background:var(--red-dim);border-color:rgba(255,75,80,0.2)}
.alert-list-item.warn{background:var(--amber-dim);border-color:rgba(255,180,50,0.2)}
.alert-list-item.info{background:var(--blue-dim);border-color:rgba(60,160,255,0.2)}
.alert-icon{font-size:16px;margin-top:1px}
.alert-text{font-size:13px;font-weight:500}
.alert-list-item.crit .alert-text{color:var(--red)}
.alert-list-item.warn .alert-text{color:var(--amber)}
.alert-list-item.info .alert-text{color:var(--blue)}
.alert-sub{font-size:11px;color:var(--text2);margin-top:2px}
.no-alerts{display:flex;align-items:center;gap:10px;padding:14px;background:var(--green-dim);border-radius:var(--radius-sm);border:1px solid rgba(50,210,130,0.2);color:var(--green);font-size:13px;font-weight:500}

/* REC TABLE */
.rec-table{width:100%;border-collapse:collapse}
.rec-table th{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.6px;padding:8px 10px;text-align:left;border-bottom:1px solid var(--border)}
.rec-table td{font-size:13px;padding:10px;border-bottom:1px solid var(--border);color:var(--text2);vertical-align:top}
.rec-table td:first-child{color:var(--text)}
.rec-table tr:last-child td{border-bottom:none}
.pri-badge{font-size:10px;font-weight:700;padding:3px 8px;border-radius:8px;text-transform:uppercase;letter-spacing:0.4px;display:inline-block}
.pri-high{background:var(--red-dim);color:var(--red)}
.pri-med{background:var(--amber-dim);color:var(--amber)}
.pri-low{background:var(--green-dim);color:var(--green)}

/* FATIGUE ANALYSIS */
.fatigue-analysis{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem}
.fatigue-big-bar{height:20px;background:linear-gradient(90deg,var(--green),var(--amber) 50%,var(--red));border-radius:10px;position:relative;margin:1rem 0;overflow:visible}
.fatigue-pointer{position:absolute;top:-6px;width:3px;height:32px;background:var(--text);border-radius:2px;transform:translateX(-50%)}
.fatigue-pointer::after{content:attr(data-val);position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-size:11px;color:var(--text);font-family:'Space Grotesk',sans-serif;font-weight:600;white-space:nowrap}
.fatigue-zones{display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-top:4px}
.fatigue-prediction{margin-top:1rem;padding:10px;background:var(--bg3);border-radius:var(--radius-sm);font-size:13px;color:var(--text2);display:flex;align-items:center;gap:8px}
.fatigue-prediction strong{color:var(--text)}

/* ROI SECTION */
.roi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.5rem}
.roi-card{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.25rem;text-align:center}
.roi-val{font-size:24px;font-weight:700;font-family:'Space Grotesk',sans-serif;color:var(--green)}
.roi-label{font-size:11px;color:var(--text2);margin-top:4px}
.roi-sub{font-size:10px;color:var(--text3);margin-top:2px}

/* BACK BTN */
.back-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--text2);cursor:pointer;padding:6px 12px;border-radius:var(--radius-xs);border:1px solid var(--border);background:var(--bg2);transition:all 0.15s;margin-bottom:1rem}
.back-btn:hover{color:var(--text);border-color:var(--border2)}

/* GLOW EFFECTS */
.glow-red{box-shadow:0 0 20px rgba(255,75,80,0.15)}
.glow-green{box-shadow:0 0 20px rgba(50,210,130,0.1)}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo" onclick="goHome()">
    <div class="nav-logo-mark">LG</div>
    <div class="nav-logo-text"><span>Loom</span>Guard</div>
  </div>
  <div id="breadcrumb" class="nav-center">
    <span class="nav-crumb active" onclick="goHome()">Plant Floor</span>
  </div>
  <div class="nav-right">
    <div class="nav-tabs">
      <button class="nav-tab active" id="tab-home" onclick="goHome()">Home</button>
      <button class="nav-tab" id="tab-overview" onclick="goOverview()">Overview</button>
    </div>
    <div class="live-badge"><div class="live-dot"></div>Live</div>
    <div class="nav-time" id="clock">--:--:--</div>
  </div>
</nav>

<!-- HOME PAGE -->
<div class="page active" id="page-home">
  <div class="container">
    <div class="home-hero">
      <div class="home-hero-top">
        <div>
          <h1 class="home-title">Plant Floor<br><span>Machine Monitor</span></h1>
          <p class="home-sub">Ludhiana Textile Unit — 12 machines across 4 departments</p>
        </div>
        <div class="pill-row" id="summary-pills"></div>
      </div>
    </div>

    <div class="cat-grid" id="cat-grid"></div>

    <div>
      <div class="alerts-strip-title">Recent Alerts</div>
      <div class="alerts-strip" id="alerts-strip"></div>
    </div>
  </div>
</div>

<!-- OVERVIEW PAGE -->
<div class="page" id="page-overview">
  <div class="container">
    <h2 style="font-size:20px;font-weight:700;margin-bottom:1.25rem;color:var(--text)">Fleet Overview</h2>
    <div class="metric-grid">
      <div class="metric-card"><div class="metric-label">Active Machines</div><div class="metric-val purple">12<span style="font-size:14px;color:var(--text2)">/14</span></div><div class="metric-sub">2 offline for service</div></div>
      <div class="metric-card"><div class="metric-label">Fleet Health</div><div class="metric-val warn">71%</div><div class="metric-sub">↓ 4% this week</div></div>
      <div class="metric-card"><div class="metric-label">Active Alerts</div><div class="metric-val crit">4</div><div class="metric-sub">1 critical · 3 warnings</div></div>
      <div class="metric-card"><div class="metric-label">Uptime Today</div><div class="metric-val good">94.2%</div><div class="metric-sub">Target: 95%</div></div>
    </div>

    <div class="chart-row">
      <div class="chart-card">
        <div class="chart-title">Fleet health — last 7 days</div>
        <div class="chart-wrap" style="height:180px"><canvas id="ov-trend" role="img" aria-label="Fleet health trend"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Fault distribution</div>
        <div class="chart-wrap" style="height:180px"><canvas id="ov-fault" role="img" aria-label="Fault types"></canvas></div>
      </div>
    </div>

    <div class="chart-card" style="margin-bottom:16px">
      <div class="chart-title">Critical machine M-04 — sensor readings vs safe limits</div>
      <div class="chart-wrap" style="height:200px"><canvas id="ov-sensor" role="img" aria-label="M04 sensors"></canvas></div>
    </div>

